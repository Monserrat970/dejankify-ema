# ─── Database ─────────────────────────────────────────────────────
# Local Docker:
DATABASE_URL="postgresql://dejankify:dejankify_dev@localhost:5432/dejankify"
# Neon (production):
# DATABASE_URL="postgresql://user:password@ep-xxx.us-east-2.aws.neon.tech/dejankify?sslmode=require"

# ─── Auth.js ──────────────────────────────────────────────────────
# Generate with: npx auth secret
AUTH_SECRET=""
# Production example: https://your-app-name.up.railway.app
AUTH_URL=""
# Required when running behind a reverse proxy in production
AUTH_TRUST_HOST="true"
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""

# ─── Anthropic ────────────────────────────────────────────────────
ANTHROPIC_API_KEY=""

# ─── PageSpeed Insights (optional — works without key at lower rate limits) ──
PAGESPEED_API_KEY=""

# ─── Rate Limits ──────────────────────────────────────────────────
# Max analyses per user per day
DAILY_ANALYSIS_LIMIT=15
# Max estimated API cost per user per day (in cents)
DAILY_COST_LIMIT_CENTS=200
